<?xml version="1.0" encoding="utf-8"?>
<!--
  activity_leave_request.xml — PREMIUM REDESIGN
  ALL IDs preserved:
    etLeaveReason | etLeaveDate | cardAttachDoc | ivDocPreview
    btnSubmitLeave | recyclerLeaveHistory | progressBar
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ══ NAVY HEADER ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A237E"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="36dp"
            android:paddingBottom="24dp"
            android:elevation="10dp">

            <TextView
                android:text="Absence Request"
                android:textSize="12sp"
                android:textColor="#90CAF9"
                android:letterSpacing="0.04"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Submit Leave Request"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginTop="2dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Fill in the details and attach supporting documents if needed"
                android:textSize="13sp"
                android:textColor="#90CAF9"
                android:layout_marginTop="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- ══ BODY ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="18dp"
            android:paddingBottom="24dp">

            <!-- SECTION LABEL -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">
                <View android:layout_width="3dp" android:layout_height="18dp" android:background="#1A237E" android:layout_marginEnd="10dp"/>
                <TextView android:text="Request Details" android:textStyle="bold" android:textColor="#1A237E" android:textSize="15sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- FORM CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="5dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeWidth="0dp"
                android:layout_marginBottom="14dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <View android:layout_width="match_parent" android:layout_height="4dp" android:background="#1A237E"/>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="18dp"
                        android:paddingBottom="18dp">

                        <!-- Reason textarea -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="14dp"
                            android:hint="Reason for leave..."
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp"
                            app:boxStrokeColor="#1A237E"
                            app:hintTextColor="#1A237E">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etLeaveReason"
                                android:layout_width="match_parent"
                                android:layout_height="120dp"
                                android:gravity="top|start"
                                android:textColor="#212121"
                                android:padding="14dp"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Date field -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Date (DD/MM/YYYY)"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp"
                            app:boxStrokeColor="#1A237E"
                            app:hintTextColor="#1A237E"
                            app:startIconDrawable="@android:drawable/ic_menu_my_calendar"
                            app:startIconTint="#1A237E">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etLeaveDate"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="#212121"
                                android:focusable="false"
                                android:clickable="true"
                                android:padding="14dp"/>
                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ATTACHMENT SECTION LABEL -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">
                <View android:layout_width="3dp" android:layout_height="18dp" android:background="#E65100" android:layout_marginEnd="10dp"/>
                <TextView android:text="Attach Supporting Document" android:textStyle="bold" android:textColor="#1A237E" android:textSize="15sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- ATTACHMENT CARD -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardAttachDoc"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="18dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:background="#EEF2FF">
                    <ImageView
                        android:id="@+id/ivDocPreview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerInside"
                        android:src="@android:drawable/ic_menu_camera"
                        android:padding="50dp"
                        android:alpha="0.35"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- SUBMIT BUTTON -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnSubmitLeave"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="📤  SUBMIT REQUEST"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="15sp"
                android:background="@drawable/btn_primary"
                android:elevation="4dp"
                android:layout_marginBottom="24dp"/>

            <!-- LEAVE HISTORY SECTION LABEL -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">
                <View android:layout_width="3dp" android:layout_height="18dp" android:background="#1A237E" android:layout_marginEnd="10dp"/>
                <TextView android:text="Your Leave History" android:textStyle="bold" android:textColor="#1A237E" android:textSize="15sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- HISTORY LIST CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeWidth="0dp"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <View android:layout_width="match_parent" android:layout_height="4dp" android:background="#1565C0"/>
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerLeaveHistory"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:clipToPadding="false"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- PROGRESS BAR -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone"/>

        </LinearLayout>
    </LinearLayout>
</ScrollView>
