<?xml version="1.0" encoding="utf-8"?>
<!--
  dialog_leave_details.xml — PREMIUM REDESIGN
  ALL IDs preserved:
    tvDialogReason | ivCertificate
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Dialog header bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1A237E"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="18dp"
        android:paddingBottom="18dp">
        <TextView
            android:text="Leave Request Details"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- Body -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Reason section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">
            <View android:layout_width="3dp" android:layout_height="16dp" android:background="#1A237E" android:layout_marginEnd="10dp"/>
            <TextView android:text="Reason" android:textStyle="bold" android:textColor="#1A237E" android:textSize="13sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#F4F6FF"
            app:strokeWidth="0dp"
            android:layout_marginBottom="20dp">
            <TextView
                android:id="@+id/tvDialogReason"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Reason will appear here"
                android:textSize="14sp"
                android:textColor="#212121"
                android:lineSpacingMultiplier="1.4"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"/>
        </com.google.android.material.card.MaterialCardView>

        <!-- Attachment section label -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">
            <View android:layout_width="3dp" android:layout_height="16dp" android:background="#1A237E" android:layout_marginEnd="10dp"/>
            <TextView android:text="Attachment Preview" android:textStyle="bold" android:textColor="#1A237E" android:textSize="13sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Image card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="260dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#EEF2FF"
            app:strokeWidth="0dp">
            <ImageView
                android:id="@+id/ivCertificate"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerInside"
                android:src="@android:drawable/ic_menu_gallery"
                android:padding="8dp"/>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</LinearLayout>
