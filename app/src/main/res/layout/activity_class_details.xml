<?xml version="1.0" encoding="utf-8"?>
<!--
  activity_class_details.xml — PREMIUM REDESIGN
  ALL IDs preserved:
    tvClassName | chipSessionStatus | tvStudentCount | tvRadius
    btnStart | cardStartAttendance | cardManageStudents | cardReports | cardSettings
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ══ NAVY HEADER BANNER ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A237E"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="36dp"
            android:paddingBottom="24dp"
            android:elevation="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:text="Class Overview"
                        android:textSize="12sp"
                        android:textColor="#90CAF9"
                        android:letterSpacing="0.04"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:id="@+id/tvClassName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CSS - 1st"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <!-- Session status chip (top-right) -->
                <com.google.android.material.chip.Chip
                    android:id="@+id/chipSessionStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Inactive"
                    android:textColor="@android:color/white"
                    app:chipBackgroundColor="@color/gray"
                    app:chipCornerRadius="20dp"
                    app:chipIcon="@drawable/ic_circle"
                    app:chipIconTint="@android:color/white"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ══ BODY ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="18dp"
            android:paddingBottom="24dp">

            <!-- STATS ROW: Students + Radius -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="5dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:strokeWidth="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                        <View android:layout_width="match_parent" android:layout_height="4dp" android:background="#1A237E"/>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingStart="16dp" android:paddingEnd="16dp" android:paddingTop="14dp" android:paddingBottom="16dp">
                            <TextView android:id="@+id/tvStudentCount" android:text="0" android:textSize="32sp" android:textStyle="bold" android:textColor="#0D47A1" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            <TextView android:text="Students" android:textSize="12sp" android:textStyle="bold" android:textColor="#90A4AE" android:layout_marginTop="2dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="5dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:strokeWidth="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                        <View android:layout_width="match_parent" android:layout_height="4dp" android:background="#43A047"/>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingStart="16dp" android:paddingEnd="16dp" android:paddingTop="14dp" android:paddingBottom="16dp">
                            <TextView android:id="@+id/tvRadius" android:text="50m" android:textSize="32sp" android:textStyle="bold" android:textColor="#1B5E20" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            <TextView android:text="Radius" android:textSize="12sp" android:textStyle="bold" android:textColor="#90A4AE" android:layout_marginTop="2dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- START SESSION CTA -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStart"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="▶  START SESSION"
                android:textAllCaps="true"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textSize="15sp"
                android:letterSpacing="0.04"
                app:cornerRadius="14dp"
                app:backgroundTint="#1A237E"
                android:layout_marginBottom="20dp"/>

            <!-- Section label -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">
                <View android:layout_width="3dp" android:layout_height="18dp" android:background="#1A237E" android:layout_marginEnd="10dp"/>
                <TextView android:text="Quick Actions" android:textStyle="bold" android:textColor="#1A237E" android:textSize="15sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- QUICK ACTION GRID -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2">

                <!-- Live Session — white card with green accent (matches other cards) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardStartAttendance"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="5dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:strokeWidth="0dp">
                    <LinearLayout android:gravity="center" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="16dp">
                        <View android:layout_width="24dp" android:layout_height="3dp" android:background="#00897B" android:layout_marginBottom="12dp"/>
                        <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_attendance" app:tint="#00897B"/>
                        <TextView android:text="Live Session" android:textColor="#1A237E" android:textStyle="bold" android:textSize="13sp" android:layout_marginTop="10dp" android:gravity="center" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Manage Students -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardManageStudents"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="5dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:strokeWidth="0dp">
                    <LinearLayout android:gravity="center" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="16dp">
                        <View android:layout_width="24dp" android:layout_height="3dp" android:background="#43A047" android:layout_marginBottom="12dp"/>
                        <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_students" app:tint="#1A237E"/>
                        <TextView android:text="Manage Students" android:textColor="#1A237E" android:textStyle="bold" android:textSize="13sp" android:layout_marginTop="10dp" android:gravity="center" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Attendance Reports -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardReports"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="5dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:strokeWidth="0dp">
                    <LinearLayout android:gravity="center" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="16dp">
                        <View android:layout_width="24dp" android:layout_height="3dp" android:background="#1565C0" android:layout_marginBottom="12dp"/>
                        <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_reports" app:tint="#1565C0"/>
                        <TextView android:text="Attendance Reports" android:textColor="#1A237E" android:textStyle="bold" android:textSize="13sp" android:layout_marginTop="10dp" android:gravity="center" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Classroom Settings -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardSettings"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="5dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:strokeWidth="0dp">
                    <LinearLayout android:gravity="center" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="16dp">
                        <View android:layout_width="24dp" android:layout_height="3dp" android:background="#E65100" android:layout_marginBottom="12dp"/>
                        <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_settings" app:tint="#E65100"/>
                        <TextView android:text="Classroom Settings" android:textColor="#1A237E" android:textStyle="bold" android:textSize="13sp" android:layout_marginTop="10dp" android:gravity="center" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </GridLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>

