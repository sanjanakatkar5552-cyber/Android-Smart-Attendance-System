<?xml version="1.0" encoding="utf-8"?>
<!--
  activity_attendance_records.xml  — PREMIUM REDESIGN
  ─────────────────────────────────────────────────────────────
  ALL IDs preserved:
    searchStudent | cbTodayOnly | tvTodayTag
    btnSelectDate | btnClearDate | spinnerSubject
    tvPresentCount | tvAbsentCount | tvRecordCount
    tvSelectedDateLabel | recyclerAttendance
  ─────────────────────────────────────────────────────────────
  Column weights (must match item_attendance_record.xml):
    Name 2 | Roll 1.2 | Subject 1.5 | Date 1.5 | Location 2 | Status 1.3
  minWidth = 900dp
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F6FF">

    <!-- ═══════════════════════════════════════════════════════
         GRADIENT HEADER
         ═══════════════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1A237E"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="32dp"
        android:paddingBottom="20dp"
        android:elevation="10dp">

        <!-- Row: icon + text + live pill -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Title block -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:text="Attendance Records"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/tvSelectedDateLabel"
                    android:text="Today  •  All"
                    android:textSize="12sp"
                    android:textColor="#90CAF9"
                    android:layout_marginTop="3dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- Live indicator pill -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#283593"
                android:paddingStart="10dp"
                android:paddingEnd="12dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp">

                <View
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:background="#69F0AE"
                    android:layout_marginEnd="5dp"/>

                <TextView
                    android:text="LIVE"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:textColor="#69F0AE"
                    android:letterSpacing="0.12"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- ═══════════════════════════════════════════════════════
         SCROLLABLE BODY
         Use NestedScrollView (not plain ScrollView) so the
         RecyclerView inside renders ALL rows instead of only
         the ~6 that fit the visible viewport.
         ═══════════════════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:background="#F4F6FF">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="18dp"
            android:paddingBottom="24dp">

            <!-- ① SEARCH BAR -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="52dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeWidth="0dp"
                android:layout_marginBottom="12dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">
                    <TextView
                        android:text="🔍"
                        android:textSize="15sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="10dp"/>
                    <EditText
                        android:id="@+id/searchStudent"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:hint="Search student name or roll no…"
                        android:textSize="14sp"
                        android:textColor="#212121"
                        android:textColorHint="#BDBDBD"
                        android:background="@null"
                        android:inputType="text"
                        android:maxLines="1"
                        android:imeOptions="actionSearch"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ② FILTER CARD: Today toggle + date + subject -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeWidth="0dp"
                android:layout_marginBottom="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Today toggle -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="12dp">

                        <CheckBox
                            android:id="@+id/cbTodayOnly"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            android:buttonTint="#1A237E"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="10dp">
                            <TextView
                                android:text="Show Today's Records Only"
                                android:textSize="14sp"
                                android:textColor="#1A237E"
                                android:textStyle="bold"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>
                            <TextView
                                android:text="Uncheck to browse all dates"
                                android:textSize="11sp"
                                android:textColor="#BDBDBD"
                                android:layout_marginTop="1dp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>
                        </LinearLayout>

                        <!-- TODAY badge -->
                        <TextView
                            android:id="@+id/tvTodayTag"
                            android:text="TODAY"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:letterSpacing="0.1"
                            android:paddingStart="9dp"
                            android:paddingEnd="9dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:background="#1A237E"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>

                    <!-- Separator -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F0F0F0"
                        android:layout_marginStart="14dp"
                        android:layout_marginEnd="14dp"/>

                    <!-- Date + Clear + Subject row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:orientation="horizontal"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="5dp"
                        android:paddingBottom="5dp"
                        android:gravity="center_vertical">

                        <Button
                            android:id="@+id/btnSelectDate"
                            android:layout_width="0dp"
                            android:layout_weight="1.4"
                            android:layout_height="38dp"
                            android:text="📅  Pick Date"
                            android:textSize="11sp"
                            android:textColor="#1A237E"
                            android:backgroundTint="#EEF2FF"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:layout_marginEnd="6dp"
                            app:cornerRadius="10dp"
                            style="@style/Widget.MaterialComponents.Button.TextButton"/>

                        <Button
                            android:id="@+id/btnClearDate"
                            android:layout_width="0dp"
                            android:layout_weight="0.9"
                            android:layout_height="38dp"
                            android:text="✕ Clear"
                            android:textSize="11sp"
                            android:textColor="#B71C1C"
                            android:backgroundTint="#FFEBEE"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:layout_marginEnd="6dp"
                            app:cornerRadius="10dp"
                            style="@style/Widget.MaterialComponents.Button.TextButton"/>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_weight="1.2"
                            android:layout_height="38dp"
                            app:cardCornerRadius="10dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#EEF2FF"
                            app:strokeWidth="0dp">
                            <Spinner
                                android:id="@+id/spinnerSubject"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:paddingStart="10dp"
                                android:paddingEnd="4dp"
                                android:background="@null"/>
                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>

                    <!-- Lecture / Session filter row (NEW) -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F0F0F0"
                        android:layout_marginStart="14dp"
                        android:layout_marginEnd="14dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:orientation="horizontal"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:text="Lecture:"
                            android:textSize="12sp"
                            android:textColor="#1A237E"
                            android:textStyle="bold"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="10dp"/>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="38dp"
                            app:cardCornerRadius="10dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#EEF2FF"
                            app:strokeWidth="0dp">
                            <Spinner
                                android:id="@+id/spinnerLecture"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:paddingStart="10dp"
                                android:paddingEnd="4dp"
                                android:background="@null"/>
                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ③ STATS ROW: Present + Absent (side by side with top accent) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="14dp">

                <!-- Present card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="5dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:strokeWidth="0dp"
                    android:layout_marginEnd="8dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <!-- Green accent top bar -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="4dp"
                            android:background="#43A047"/>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:paddingTop="14dp"
                            android:paddingBottom="16dp">
                            <TextView
                                android:id="@+id/tvPresentCount"
                                android:text="0"
                                android:textSize="36sp"
                                android:textStyle="bold"
                                android:textColor="#1B5E20"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>
                            <TextView
                                android:text="✔  Present"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="#43A047"
                                android:layout_marginTop="2dp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Absent card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="5dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:strokeWidth="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <!-- Red accent top bar -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="4dp"
                            android:background="#E53935"/>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:paddingTop="14dp"
                            android:paddingBottom="16dp">
                            <TextView
                                android:id="@+id/tvAbsentCount"
                                android:text="0"
                                android:textSize="36sp"
                                android:textStyle="bold"
                                android:textColor="#B71C1C"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>
                            <TextView
                                android:text="✘  Absent"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="#E53935"
                                android:layout_marginTop="2dp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- ④ TABLE CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="5dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Table title row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="10dp">

                        <!-- Left accent line -->
                        <View
                            android:layout_width="3dp"
                            android:layout_height="18dp"
                            android:background="#1A237E"
                            android:layout_marginEnd="10dp"/>

                        <TextView
                            android:text="Student Records"
                            android:textColor="#1A237E"
                            android:textStyle="bold"
                            android:textSize="15sp"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"/>

                        <!-- Count pill -->
                        <TextView
                            android:id="@+id/tvRecordCount"
                            android:text="0 records"
                            android:textSize="11sp"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:background="#1A237E"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F0F0F0"/>

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="horizontal">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:minWidth="900dp">

                            <!-- HEADER ROW -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="44dp"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:background="#1A237E">

                                <TextView android:text="Name"
                                    android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="12sp"
                                    android:paddingStart="14dp" android:paddingEnd="8dp"
                                    android:layout_width="0dp" android:layout_weight="2"
                                    android:layout_height="match_parent" android:gravity="center_vertical"/>
                                <View android:layout_width="1dp" android:layout_height="22dp" android:background="#3949AB"/>

                                <TextView android:text="Roll No"
                                    android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="12sp"
                                    android:paddingStart="10dp" android:paddingEnd="6dp"
                                    android:layout_width="0dp" android:layout_weight="1.2"
                                    android:layout_height="match_parent" android:gravity="center_vertical"/>
                                <View android:layout_width="1dp" android:layout_height="22dp" android:background="#3949AB"/>

                                <TextView android:text="Subject"
                                    android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="12sp"
                                    android:paddingStart="10dp" android:paddingEnd="6dp"
                                    android:layout_width="0dp" android:layout_weight="1.5"
                                    android:layout_height="match_parent" android:gravity="center_vertical"/>
                                <View android:layout_width="1dp" android:layout_height="22dp" android:background="#3949AB"/>

                                <TextView android:text="Date"
                                    android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="12sp"
                                    android:paddingStart="10dp" android:paddingEnd="6dp"
                                    android:layout_width="0dp" android:layout_weight="1.5"
                                    android:layout_height="match_parent" android:gravity="center_vertical"/>
                                <View android:layout_width="1dp" android:layout_height="22dp" android:background="#3949AB"/>

                                <TextView android:text="Location"
                                    android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="12sp"
                                    android:paddingStart="10dp" android:paddingEnd="6dp"
                                    android:layout_width="0dp" android:layout_weight="2"
                                    android:layout_height="match_parent" android:gravity="center_vertical"/>
                                <View android:layout_width="1dp" android:layout_height="22dp" android:background="#3949AB"/>

                                <TextView android:text="Status"
                                    android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="12sp"
                                    android:paddingStart="10dp" android:paddingEnd="10dp"
                                    android:layout_width="0dp" android:layout_weight="1.3"
                                    android:layout_height="match_parent" android:gravity="center"/>

                            </LinearLayout>

                            <!-- DATA ROWS -->
                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/recyclerAttendance"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:minWidth="900dp"
                                android:background="#FFFFFF"
                                android:nestedScrollingEnabled="true"/>

                        </LinearLayout>
                    </HorizontalScrollView>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>