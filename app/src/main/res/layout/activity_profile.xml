<?xml version="1.0" encoding="utf-8"?>
<!--
  activity_profile.xml — PREMIUM REDESIGN
  ALL IDs preserved:
    imgAvatar | btnEditPhoto | tvRole | tvName | etEmail | etMobile
    etDepartment | etYear | etRollNo | btnUpdateProfile | btnChangePassword | progressBar
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6FF">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ══ NAVY HEADER with Avatar ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#1A237E"
                android:gravity="center"
                android:paddingTop="40dp"
                android:paddingBottom="28dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:elevation="10dp">

                <!-- Avatar + edit badge -->
                <FrameLayout
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:layout_marginBottom="12dp">

                    <ImageView
                        android:id="@+id/imgAvatar"
                        android:layout_width="96dp"
                        android:layout_height="96dp"
                        android:src="@drawable/ic_profile"
                        android:background="@drawable/bg_white_circle"
                        android:scaleType="centerCrop"
                        android:elevation="4dp"/>

                    <ImageView
                        android:id="@+id/btnEditPhoto"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="bottom|end"
                        android:layout_margin="2dp"
                        android:background="@drawable/bg_white_circle"
                        android:padding="5dp"
                        android:src="@android:drawable/ic_menu_camera"
                        android:elevation="8dp"/>
                </FrameLayout>

                <TextView
                    android:id="@+id/tvRole"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="STUDENT"
                    android:textColor="#90CAF9"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.10"
                    android:background="#283593"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"/>

            </LinearLayout>

            <!-- ══ FORM BODY ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="24dp"
                android:paddingBottom="32dp">

                <!-- Section: Personal Info -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">
                    <View android:layout_width="3dp" android:layout_height="18dp" android:background="#1A237E" android:layout_marginEnd="10dp"/>
                    <TextView android:text="Personal Information" android:textStyle="bold" android:textColor="#1A237E" android:textSize="14sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

                <!-- Full Name -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Full Name" android:textColor="#546E7A" android:textSize="11sp" android:textStyle="bold" android:letterSpacing="0.04" android:layout_marginBottom="6dp"/>
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent" android:layout_height="54dp" android:layout_marginBottom="14dp"
                    app:cardCornerRadius="14dp" app:cardElevation="4dp" app:cardBackgroundColor="#FFFFFF" app:strokeWidth="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="16dp" android:paddingEnd="16dp">
                        <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_profile" app:tint="#90A4AE" android:layout_marginEnd="12dp"/>
                        <EditText android:id="@+id/tvName" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@null" android:hint="Full Name" android:padding="0dp" android:textColor="#1A237E" android:textColorHint="#B0BEC5" android:textSize="14sp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Email -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Email Address" android:textColor="#546E7A" android:textSize="11sp" android:textStyle="bold" android:letterSpacing="0.04" android:layout_marginBottom="6dp"/>
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent" android:layout_height="54dp" android:layout_marginBottom="14dp"
                    app:cardCornerRadius="14dp" app:cardElevation="2dp" app:cardBackgroundColor="#F5F5F5" app:strokeWidth="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="16dp" android:paddingEnd="16dp">
                        <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_email" app:tint="#B0BEC5" android:layout_marginEnd="12dp"/>
                        <EditText android:id="@+id/etEmail" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@null" android:hint="Email" android:enabled="false" android:padding="0dp" android:textColor="#90A4AE" android:textColorHint="#B0BEC5" android:textSize="14sp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Mobile -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mobile Number" android:textColor="#546E7A" android:textSize="11sp" android:textStyle="bold" android:letterSpacing="0.04" android:layout_marginBottom="6dp"/>
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent" android:layout_height="54dp" android:layout_marginBottom="14dp"
                    app:cardCornerRadius="14dp" app:cardElevation="4dp" app:cardBackgroundColor="#FFFFFF" app:strokeWidth="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="16dp" android:paddingEnd="16dp">
                        <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_mobile" app:tint="#90A4AE" android:layout_marginEnd="12dp"/>
                        <EditText android:id="@+id/etMobile" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@null" android:hint="Mobile Number" android:inputType="phone" android:padding="0dp" android:textColor="#1A237E" android:textColorHint="#B0BEC5" android:textSize="14sp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Section: Academic Info -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="16dp">
                    <View android:layout_width="3dp" android:layout_height="18dp" android:background="#43A047" android:layout_marginEnd="10dp"/>
                    <TextView android:text="Academic Details" android:textStyle="bold" android:textColor="#1A237E" android:textSize="14sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

                <!-- Department -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Department" android:textColor="#546E7A" android:textSize="11sp" android:textStyle="bold" android:letterSpacing="0.04" android:layout_marginBottom="6dp"/>
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent" android:layout_height="54dp" android:layout_marginBottom="14dp"
                    app:cardCornerRadius="14dp" app:cardElevation="4dp" app:cardBackgroundColor="#FFFFFF" app:strokeWidth="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center_vertical" android:paddingStart="16dp" android:paddingEnd="16dp">
                        <EditText android:id="@+id/etDepartment" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@null" android:hint="Department" android:padding="0dp" android:textColor="#1A237E" android:textColorHint="#B0BEC5" android:textSize="14sp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Two-column: Year + Roll No (student-only row) -->
                <LinearLayout android:id="@+id/layoutYearRollRow" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="28dp">
                    <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginEnd="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Year" android:textColor="#546E7A" android:textSize="11sp" android:textStyle="bold" android:layout_marginBottom="6dp"/>
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent" android:layout_height="54dp"
                            app:cardCornerRadius="14dp" app:cardElevation="4dp" app:cardBackgroundColor="#FFFFFF" app:strokeWidth="0dp">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center_vertical" android:paddingStart="14dp" android:paddingEnd="14dp">
                                <EditText android:id="@+id/etYear" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@null" android:hint="FY/SY/TY" android:padding="0dp" android:textColor="#1A237E" android:textColorHint="#B0BEC5" android:textSize="14sp"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Roll Number" android:textColor="#546E7A" android:textSize="11sp" android:textStyle="bold" android:layout_marginBottom="6dp"/>
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent" android:layout_height="54dp"
                            app:cardCornerRadius="14dp" app:cardElevation="4dp" app:cardBackgroundColor="#FFFFFF" app:strokeWidth="0dp">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center_vertical" android:paddingStart="14dp" android:paddingEnd="14dp">
                                <EditText android:id="@+id/etRollNo" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@null" android:hint="Roll No." android:inputType="number" android:padding="0dp" android:textColor="#1A237E" android:textColorHint="#B0BEC5" android:textSize="14sp"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>
                </LinearLayout>

                <!-- UPDATE Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnUpdateProfile"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="Update Profile"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    app:cornerRadius="14dp"
                    app:backgroundTint="#1A237E"
                    android:elevation="6dp"/>

                <!-- CHANGE PASSWORD Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnChangePassword"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="12dp"
                    android:text="Change Password"
                    android:textColor="#1A237E"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    app:cornerRadius="14dp"
                    app:backgroundTint="#E8EAF6"
                    app:strokeColor="#1A237E"
                    app:strokeWidth="1dp"
                    android:elevation="2dp"/>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"
        android:indeterminateTint="@color/colorPrimary"/>

</FrameLayout>
