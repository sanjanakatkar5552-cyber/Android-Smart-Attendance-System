<?xml version="1.0" encoding="utf-8"?>
<!--
  item_class_card.xml — PREMIUM REDESIGN
  ALL IDs preserved:
    tvClassTitle | tvStudents | tvRadius | tvStatus | btnOpenClass
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginTop="10dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="5dp"
    app:cardBackgroundColor="#FFFFFF"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Colored top accent bar -->
        <View
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:background="#1A237E"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">

            <!-- Left: class info -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Class title -->
                <TextView
                    android:id="@+id/tvClassTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Java - 2nd Year"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1A237E"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginBottom="6dp"/>

                <!-- Stats row -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <!-- Students pill -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="#EEF2FF"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp"
                        android:layout_marginEnd="8dp">
                        <TextView
                            android:id="@+id/tvStudents"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="👥 Students: 0"
                            android:textColor="#1A237E"
                            android:textSize="11sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <!-- Radius pill -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="#E8F5E9"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp">
                        <TextView
                            android:id="@+id/tvRadius"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📍 50m"
                            android:textColor="#2E7D32"
                            android:textSize="11sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Status pill -->
                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Inactive"
                    android:textStyle="bold"
                    android:textSize="11sp"
                    android:textColor="#90A4AE"
                    android:background="#F5F5F5"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"/>
            </LinearLayout>

            <!-- Right: Open Class button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOpenClass"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Open →"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textSize="12sp"
                app:cornerRadius="12dp"
                app:backgroundTint="#1A237E"/>

        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
