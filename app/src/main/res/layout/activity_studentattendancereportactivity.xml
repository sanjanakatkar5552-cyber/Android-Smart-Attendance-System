<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/activity_student_attendance_report.xml -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF2FF">

    <!-- ══ HEADER ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1A237E"
        android:paddingStart="20dp" android:paddingEnd="20dp"
        android:paddingTop="24dp"  android:paddingBottom="20dp"
        android:elevation="6dp">

        <TextView
            android:text="My Attendance"
            android:textSize="22sp" android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tvSelectedDateLabel"
            android:text="All Dates  •  All Subjects"
            android:textSize="13sp" android:textColor="#90CAF9"
            android:layout_marginTop="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- ══ SCROLLABLE BODY ══ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:background="#EEF2FF">

        <LinearLayout
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- ① OVERALL % RING CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <!-- Ring / circle indicator -->
                    <View
                        android:id="@+id/overallRing"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:background="@drawable/bg_circle_green"
                        android:layout_marginEnd="20dp"/>

                    <!-- Text next to ring -->
                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content">

                        <TextView
                            android:id="@+id/tvOverallPercent"
                            android:text="0%"
                            android:textSize="36sp"
                            android:textStyle="bold"
                            android:textColor="#1A237E"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <TextView
                            android:id="@+id/tvOverallLabel"
                            android:text="Calculating..."
                            android:textSize="14sp"
                            android:textColor="#546E7A"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <TextView
                            android:text="Overall Attendance"
                            android:textSize="12sp"
                            android:textColor="#9E9E9E"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ② ALERT BANNER -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAlertBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFF3E0"
                android:layout_marginBottom="12dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvAlertBanner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp"
                    android:textColor="#E65100"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:text="⚠ Loading..."/>
            </com.google.android.material.card.MaterialCardView>

            <!-- ③ SEARCH BAR -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="52dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp" android:paddingEnd="16dp">

                    <TextView android:text="🔍" android:textSize="16sp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginEnd="10dp"/>

                    <EditText
                        android:id="@+id/searchStudent"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:hint="Search subject or date..."
                        android:textSize="14sp" android:textColor="#212121"
                        android:textColorHint="#9E9E9E"
                        android:background="@null"
                        android:inputType="text" android:maxLines="1"
                        android:imeOptions="actionSearch"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ④ DATE PICKER + CLEAR + SUBJECT SPINNER -->
            <LinearLayout
                android:orientation="horizontal"
                android:layout_marginBottom="10dp"
                android:layout_width="match_parent"
                android:layout_height="50dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="match_parent"
                    app:cardCornerRadius="12dp" app:cardElevation="3dp"
                    app:cardBackgroundColor="#FFFFFF" android:layout_marginEnd="6dp">
                    <Button
                        android:id="@+id/btnSelectDate"
                        android:layout_width="match_parent" android:layout_height="match_parent"
                        android:text="📅 Pick Date" android:textSize="11sp"
                        android:textColor="#1A237E" android:backgroundTint="#FFFFFF"
                        android:insetTop="0dp" android:insetBottom="0dp"
                        style="@style/Widget.MaterialComponents.Button.TextButton"/>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp" android:layout_weight="0.65"
                    android:layout_height="match_parent"
                    app:cardCornerRadius="12dp" app:cardElevation="3dp"
                    app:cardBackgroundColor="#FFFFFF" android:layout_marginEnd="6dp">
                    <Button
                        android:id="@+id/btnClearDate"
                        android:layout_width="match_parent" android:layout_height="match_parent"
                        android:text="✕ Clear" android:textSize="11sp"
                        android:textColor="#C62828" android:backgroundTint="#FFFFFF"
                        android:insetTop="0dp" android:insetBottom="0dp"
                        style="@style/Widget.MaterialComponents.Button.TextButton"/>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp" android:layout_weight="1.2"
                    android:layout_height="match_parent"
                    app:cardCornerRadius="12dp" app:cardElevation="3dp"
                    app:cardBackgroundColor="#FFFFFF">
                    <Spinner
                        android:id="@+id/spinnerSubject"
                        android:layout_width="match_parent" android:layout_height="match_parent"
                        android:paddingStart="12dp" android:paddingEnd="4dp"
                        android:background="@null"/>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- ⑤ SMART CHIPS -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="10dp">
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipAll"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="All Time" android:textSize="12sp" android:layout_marginEnd="6dp"
                        app:chipBackgroundColor="#1A237E" android:textColor="#FFFFFF"
                        style="@style/Widget.MaterialComponents.Chip.Action"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipToday"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Today" android:textSize="12sp" android:layout_marginEnd="6dp"
                        app:chipBackgroundColor="#FFFFFF" android:textColor="#1A237E"
                        style="@style/Widget.MaterialComponents.Chip.Action"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipWeek"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="This Week" android:textSize="12sp" android:layout_marginEnd="6dp"
                        app:chipBackgroundColor="#FFFFFF" android:textColor="#1A237E"
                        style="@style/Widget.MaterialComponents.Chip.Action"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipMonth"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="This Month" android:textSize="12sp"
                        app:chipBackgroundColor="#FFFFFF" android:textColor="#1A237E"
                        style="@style/Widget.MaterialComponents.Chip.Action"/>
                </LinearLayout>
            </HorizontalScrollView>

            <!-- ⑥ SUMMARY CARDS: Present / Absent / Total -->
            <LinearLayout
                android:orientation="horizontal"
                android:layout_marginBottom="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp" app:cardElevation="3dp"
                    app:cardBackgroundColor="#FFFFFF" android:layout_marginEnd="6dp">
                    <LinearLayout android:orientation="vertical" android:padding="14dp"
                        android:gravity="center" android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:text="✔ Present" android:textColor="#2E7D32" android:textStyle="bold" android:textSize="12sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:id="@+id/tvPresentCount" android:text="0" android:textSize="28sp" android:textStyle="bold" android:textColor="#1B5E20" android:layout_marginTop="4dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <View android:layout_width="32dp" android:layout_height="3dp" android:background="#4CAF50" android:layout_marginTop="6dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp" app:cardElevation="3dp"
                    app:cardBackgroundColor="#FFFFFF" android:layout_marginStart="3dp" android:layout_marginEnd="3dp">
                    <LinearLayout android:orientation="vertical" android:padding="14dp"
                        android:gravity="center" android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:text="✘ Absent" android:textColor="#C62828" android:textStyle="bold" android:textSize="12sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:id="@+id/tvAbsentCount" android:text="0" android:textSize="28sp" android:textStyle="bold" android:textColor="#B71C1C" android:layout_marginTop="4dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <View android:layout_width="32dp" android:layout_height="3dp" android:background="#F44336" android:layout_marginTop="6dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp" app:cardElevation="3dp"
                    app:cardBackgroundColor="#FFFFFF" android:layout_marginStart="6dp">
                    <LinearLayout android:orientation="vertical" android:padding="14dp"
                        android:gravity="center" android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:text="📋 Total" android:textColor="#1565C0" android:textStyle="bold" android:textSize="12sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:id="@+id/tvTotalCount" android:text="0" android:textSize="28sp" android:textStyle="bold" android:textColor="#0D47A1" android:layout_marginTop="4dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <View android:layout_width="32dp" android:layout_height="3dp" android:background="#1A237E" android:layout_marginTop="6dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- ⑦ BAR CHART -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:cardCornerRadius="16dp" app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF" android:layout_marginBottom="12dp">
                <LinearLayout android:orientation="vertical" android:padding="16dp"
                    android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:text="Attendance Overview" android:textColor="#1A237E"
                        android:textStyle="bold" android:textSize="15sp"
                        android:layout_marginBottom="10dp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <com.github.mikephil.charting.charts.BarChart
                        android:id="@+id/barChart"
                        android:layout_width="match_parent"
                        android:layout_height="160dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ⑧ TREND LINE CHART -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:cardCornerRadius="16dp" app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF" android:layout_marginBottom="12dp">
                <LinearLayout android:orientation="vertical" android:padding="16dp"
                    android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:text="Weekly Trend" android:textColor="#1A237E"
                        android:textStyle="bold" android:textSize="15sp"
                        android:layout_marginBottom="10dp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/lineChart"
                        android:layout_width="match_parent"
                        android:layout_height="160dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ⑨ SUBJECT BREAKDOWN -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:cardCornerRadius="16dp" app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF" android:layout_marginBottom="12dp">
                <LinearLayout android:orientation="vertical" android:padding="16dp"
                    android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:text="Subject-wise Breakdown" android:textColor="#1A237E"
                        android:textStyle="bold" android:textSize="15sp"
                        android:layout_marginBottom="10dp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView
                        android:id="@+id/tvSubjectBreakdown"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:textSize="13sp" android:textColor="#37474F"
                        android:lineSpacingMultiplier="1.6"
                        android:text="Loading..."/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ⑩ DETAILED RECORDS TABLE -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:cardCornerRadius="16dp" app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF" android:layout_marginBottom="24dp">

                <LinearLayout android:orientation="vertical"
                    android:layout_width="match_parent" android:layout_height="wrap_content">

                    <LinearLayout android:orientation="horizontal"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:paddingStart="16dp" android:paddingEnd="16dp"
                        android:paddingTop="14dp" android:paddingBottom="10dp"
                        android:gravity="center_vertical">
                        <TextView android:text="My Records" android:textColor="#1A237E"
                            android:textStyle="bold" android:textSize="15sp"
                            android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content"/>
                        <TextView android:id="@+id/tvRecordCount" android:text="0 records"
                            android:textColor="#9E9E9E" android:textSize="12sp"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E8EAF6"/>

                    <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content" android:scrollbars="horizontal">
                        <LinearLayout android:orientation="vertical"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:minWidth="900dp">

                            <!-- Table header — weights match item_attendance_record.xml -->
                            <LinearLayout android:layout_width="match_parent" android:layout_height="44dp"
                                android:orientation="horizontal" android:gravity="center_vertical"
                                android:background="#1A237E">

                                <TextView android:text="Subject" android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="12sp"
                                    android:paddingStart="14dp" android:paddingEnd="8dp"
                                    android:layout_width="0dp" android:layout_weight="2.2" android:layout_height="match_parent" android:gravity="center_vertical"/>
                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#3949AB"/>
                                <TextView android:text="Date" android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="12sp"
                                    android:paddingStart="10dp" android:layout_width="0dp" android:layout_weight="1.5" android:layout_height="match_parent" android:gravity="center_vertical"/>
                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#3949AB"/>
                                <TextView android:text="Time" android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="12sp"
                                    android:paddingStart="10dp" android:layout_width="0dp" android:layout_weight="1.3" android:layout_height="match_parent" android:gravity="center_vertical"/>
                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#3949AB"/>
                                <TextView android:text="Distance" android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="12sp"
                                    android:paddingStart="10dp" android:layout_width="0dp" android:layout_weight="1.4" android:layout_height="match_parent" android:gravity="center_vertical"/>
                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#3949AB"/>
                                <TextView android:text="Status" android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="12sp"
                                    android:paddingStart="6dp" android:layout_width="0dp" android:layout_weight="1.3" android:layout_height="match_parent" android:gravity="center"/>
                            </LinearLayout>

                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/recyclerAttendance"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:minWidth="900dp"
                                android:background="#FFFFFF"
                                android:nestedScrollingEnabled="false"/>
                        </LinearLayout>
                    </HorizontalScrollView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</LinearLayout>