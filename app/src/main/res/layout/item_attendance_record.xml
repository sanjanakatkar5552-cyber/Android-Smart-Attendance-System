<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/item_attendance_record.xml
     COLUMN WEIGHTS — must match the header row in activity_attendance_report.xml exactly:
       Name      2.2  | Roll No  1.2 | Subject  1.5 | Date  1.5
       Time      1.3  | Att.%    1.2 | Status   1.3
     minWidth on root = 1100dp  (same as RecyclerView and its parent LinearLayout)
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="46dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:minWidth="1100dp">

    <!-- NAME -->
    <TextView
        android:id="@+id/txtName"
        android:layout_width="0dp"
        android:layout_weight="2.2"
        android:layout_height="match_parent"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="6dp"
        android:textSize="12sp"
        android:textColor="#1A237E"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end"/>

    <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#E8EAF6"/>

    <!-- ROLL NO -->
    <TextView
        android:id="@+id/txtRoll"
        android:layout_width="0dp"
        android:layout_weight="1.2"
        android:layout_height="match_parent"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:paddingEnd="6dp"
        android:textSize="12sp"
        android:textColor="#37474F"
        android:maxLines="1"
        android:ellipsize="end"/>

    <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#E8EAF6"/>

    <!-- SUBJECT -->
    <TextView
        android:id="@+id/txtSubject"
        android:layout_width="0dp"
        android:layout_weight="1.5"
        android:layout_height="match_parent"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:paddingEnd="6dp"
        android:textSize="12sp"
        android:textColor="#37474F"
        android:maxLines="1"
        android:ellipsize="end"/>

    <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#E8EAF6"/>

    <!-- DATE -->
    <TextView
        android:id="@+id/txtDate"
        android:layout_width="0dp"
        android:layout_weight="1.5"
        android:layout_height="match_parent"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:paddingEnd="6dp"
        android:textSize="12sp"
        android:textColor="#37474F"
        android:maxLines="1"/>

    <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#E8EAF6"/>

    <!-- TIME -->
    <TextView
        android:id="@+id/txtTime"
        android:layout_width="0dp"
        android:layout_weight="1.3"
        android:layout_height="match_parent"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:paddingEnd="6dp"
        android:textSize="12sp"
        android:textColor="#546E7A"
        android:maxLines="1"/>

    <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#E8EAF6"/>

    <!-- ATTENDANCE % -->
    <TextView
        android:id="@+id/txtAttendancePercent"
        android:layout_width="0dp"
        android:layout_weight="1.2"
        android:layout_height="match_parent"
        android:gravity="center"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:textSize="12sp"
        android:textColor="#1565C0"
        android:textStyle="bold"
        android:maxLines="1"/>

    <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#E8EAF6"/>

    <!-- STATUS BADGE -->
    <TextView
        android:id="@+id/txtStatus"
        android:layout_width="0dp"
        android:layout_weight="1.3"
        android:layout_height="26dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_gravity="center_vertical"
        android:gravity="center"
        android:textSize="11sp"
        android:textStyle="bold"
        android:maxLines="1"/>

</LinearLayout>
