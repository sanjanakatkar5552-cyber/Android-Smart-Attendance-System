<?xml version="1.0" encoding="utf-8"?>
<!--
  activity_attendance_report.xml  — PREMIUM REDESIGN
  ─────────────────────────────────────────────────────────────
  ALL IDs preserved:
    searchStudent | btnSelectDate | btnClearDate | spinnerSubject
    chipAll | chipToday | chipWeek | chipMonth | chipLowAttendance
    tvPresentCount | tvAbsentCount | tvAttendanceRate | tvRecordCount
    tvSelectedDateLabel | tvLowAttendanceAlert | cardLowAttendanceAlert
    barChart | recyclerAttendance | btnExportPdf | btnExportExcel
  ─────────────────────────────────────────────────────────────
  Column weights (must match item_attendance_record.xml):
    Name 2.2 | Roll 1.2 | Subject 1.5 | Date 1.5 | Time 1.3 | Att.% 1.2 | Status 1.3
  minWidth = 1100dp
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F6FF">

    <!-- ═══════════════════════════════════════════════════════
         GRADIENT HEADER
         ═══════════════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1A237E"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="32dp"
        android:paddingBottom="20dp"
        android:elevation="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:text="Attendance Report"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/tvSelectedDateLabel"
                    android:text="All Dates  •  All Subjects"
                    android:textSize="12sp"
                    android:textColor="#90CAF9"
                    android:layout_marginTop="3dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- Report badge pill -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#283593"
                android:paddingStart="10dp"
                android:paddingEnd="12dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp">
                <TextView
                    android:text="📊"
                    android:textSize="11sp"
                    android:layout_marginEnd="4dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:text="REPORT"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:textColor="#90CAF9"
                    android:letterSpacing="0.12"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- ═══════════════════════════════════════════════════════
         SCROLLABLE BODY
         ═══════════════════════════════════════════════════════ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:background="#F4F6FF">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="18dp"
            android:paddingBottom="24dp">

            <!-- ① SEARCH BAR -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="52dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeWidth="0dp"
                android:layout_marginBottom="10dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">
                    <TextView
                        android:text="🔍"
                        android:textSize="15sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="10dp"/>
                    <EditText
                        android:id="@+id/searchStudent"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:hint="Search student name or roll no..."
                        android:textSize="14sp"
                        android:textColor="#212121"
                        android:textColorHint="#BDBDBD"
                        android:background="@null"
                        android:inputType="text"
                        android:maxLines="1"
                        android:imeOptions="actionSearch"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ② DATE FILTER ROW -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="52dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeWidth="0dp"
                android:layout_marginBottom="10dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp">

                    <Button
                        android:id="@+id/btnSelectDate"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="40dp"
                        android:text="📅 Pick Date"
                        android:textSize="11sp"
                        android:textColor="#1A237E"
                        android:backgroundTint="#EEF2FF"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:layout_marginEnd="6dp"
                        app:cornerRadius="10dp"
                        style="@style/Widget.MaterialComponents.Button.TextButton"/>

                    <Button
                        android:id="@+id/btnClearDate"
                        android:layout_width="0dp"
                        android:layout_weight="0.65"
                        android:layout_height="40dp"
                        android:text="✕ Clear"
                        android:textSize="11sp"
                        android:textColor="#B71C1C"
                        android:backgroundTint="#FFEBEE"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:layout_marginEnd="6dp"
                        app:cornerRadius="10dp"
                        style="@style/Widget.MaterialComponents.Button.TextButton"/>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_weight="1.2"
                        android:layout_height="40dp"
                        app:cardCornerRadius="10dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#EEF2FF"
                        app:strokeWidth="0dp">
                        <Spinner
                            android:id="@+id/spinnerSubject"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:paddingStart="12dp"
                            android:paddingEnd="4dp"
                            android:background="@null"/>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ③ SMART FILTER CHIPS -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="12dp">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="2dp">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipAll"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:text="All Time"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginEnd="6dp"
                        app:chipBackgroundColor="#1A237E"
                        android:textColor="#FFFFFF"
                        app:chipStrokeWidth="0dp"
                        style="@style/Widget.MaterialComponents.Chip.Action"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipToday"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:text="Today"
                        android:textSize="12sp"
                        android:layout_marginEnd="6dp"
                        app:chipBackgroundColor="#FFFFFF"
                        android:textColor="#1A237E"
                        app:chipStrokeColor="#C5CAE9"
                        app:chipStrokeWidth="1dp"
                        style="@style/Widget.MaterialComponents.Chip.Action"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipWeek"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:text="This Week"
                        android:textSize="12sp"
                        android:layout_marginEnd="6dp"
                        app:chipBackgroundColor="#FFFFFF"
                        android:textColor="#1A237E"
                        app:chipStrokeColor="#C5CAE9"
                        app:chipStrokeWidth="1dp"
                        style="@style/Widget.MaterialComponents.Chip.Action"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipMonth"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:text="This Month"
                        android:textSize="12sp"
                        android:layout_marginEnd="6dp"
                        app:chipBackgroundColor="#FFFFFF"
                        android:textColor="#1A237E"
                        app:chipStrokeColor="#C5CAE9"
                        app:chipStrokeWidth="1dp"
                        style="@style/Widget.MaterialComponents.Chip.Action"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipLowAttendance"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:text="⚠ Below 75%"
                        android:textSize="12sp"
                        android:layout_marginEnd="4dp"
                        app:chipBackgroundColor="#FFF3E0"
                        android:textColor="#E65100"
                        app:chipStrokeColor="#FFCC80"
                        app:chipStrokeWidth="1dp"
                        style="@style/Widget.MaterialComponents.Chip.Action"/>
                </LinearLayout>
            </HorizontalScrollView>

            <!-- ④ LOW ATTENDANCE ALERT BANNER -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLowAttendanceAlert"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFF8E1"
                app:strokeColor="#FFE082"
                app:strokeWidth="1dp"
                android:layout_marginBottom="12dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp">

                    <TextView
                        android:text="⚠"
                        android:textSize="18sp"
                        android:layout_marginEnd="10dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:id="@+id/tvLowAttendanceAlert"
                        android:text="0 students below 75% attendance"
                        android:textColor="#E65100"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ⑤ STATS ROW: Present / Absent / Rate -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <!-- Present -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="5dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:strokeWidth="0dp"
                    android:layout_marginEnd="5dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <View android:layout_width="match_parent" android:layout_height="4dp" android:background="#43A047"/>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:paddingTop="12dp"
                            android:paddingBottom="14dp">
                            <TextView android:id="@+id/tvPresentCount" android:text="0"
                                android:textSize="30sp" android:textStyle="bold" android:textColor="#1B5E20"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            <TextView android:text="✔  Present"
                                android:textSize="11sp" android:textStyle="bold" android:textColor="#43A047"
                                android:layout_marginTop="2dp"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Absent -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="5dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:strokeWidth="0dp"
                    android:layout_marginEnd="5dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <View android:layout_width="match_parent" android:layout_height="4dp" android:background="#E53935"/>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:paddingTop="12dp"
                            android:paddingBottom="14dp">
                            <TextView android:id="@+id/tvAbsentCount" android:text="0"
                                android:textSize="30sp" android:textStyle="bold" android:textColor="#B71C1C"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            <TextView android:text="✘  Absent"
                                android:textSize="11sp" android:textStyle="bold" android:textColor="#E53935"
                                android:layout_marginTop="2dp"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Rate -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="5dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:strokeWidth="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <View android:layout_width="match_parent" android:layout_height="4dp" android:background="#1A237E"/>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:paddingTop="12dp"
                            android:paddingBottom="14dp">
                            <TextView android:id="@+id/tvAttendanceRate" android:text="0%"
                                android:textSize="26sp" android:textStyle="bold" android:textColor="#0D47A1"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            <TextView android:text="📊  Rate"
                                android:textSize="11sp" android:textStyle="bold" android:textColor="#1565C0"
                                android:layout_marginTop="2dp"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- ⑥ BAR CHART CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="5dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeWidth="0dp"
                android:layout_marginBottom="12dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <View
                            android:layout_width="3dp"
                            android:layout_height="18dp"
                            android:background="#1A237E"
                            android:layout_marginEnd="10dp"/>
                        <TextView
                            android:text="Attendance Overview"
                            android:textColor="#1A237E"
                            android:textStyle="bold"
                            android:textSize="15sp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>

                    <com.github.mikephil.charting.charts.BarChart
                        android:id="@+id/barChart"
                        android:layout_width="match_parent"
                        android:layout_height="180dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ⑦ STUDENT RECORDS TABLE -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="5dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeWidth="0dp"
                android:layout_marginBottom="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Table header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="10dp">

                        <View
                            android:layout_width="3dp"
                            android:layout_height="18dp"
                            android:background="#1A237E"
                            android:layout_marginEnd="10dp"/>

                        <TextView
                            android:text="Student Records"
                            android:textColor="#1A237E"
                            android:textStyle="bold"
                            android:textSize="15sp"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"/>

                        <TextView
                            android:id="@+id/tvRecordCount"
                            android:text="0 records"
                            android:textSize="11sp"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:background="#1A237E"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F0F0F0"/>

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="horizontal">

                        <!-- Pivot table: header + rows built dynamically in showPATable() -->
                        <LinearLayout
                            android:id="@+id/tableLayout"
                            android:orientation="vertical"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                    </HorizontalScrollView>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ⑧ EXPORT BUTTONS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <Button
                    android:id="@+id/btnExportPdf"
                    android:text="↓  EXPORT PDF"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="52dp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:letterSpacing="0.03"
                    android:backgroundTint="#C62828"
                    android:layout_marginEnd="8dp"
                    app:cornerRadius="14dp"
                    style="@style/Widget.MaterialComponents.Button"/>

                <Button
                    android:id="@+id/btnExportExcel"
                    android:text="↓  EXPORT CSV"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="52dp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:letterSpacing="0.03"
                    android:backgroundTint="#2E7D32"
                    android:layout_marginStart="8dp"
                    app:cornerRadius="14dp"
                    style="@style/Widget.MaterialComponents.Button"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
